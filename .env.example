# ============================================================
# Osiris Platform — Environment Variables
# ============================================================
# Copy to .env.local and fill in real values.
# Variables marked [REQUIRED] are needed for basic local dev.
# Variables marked [OPTIONAL] are for specific integrations.
# ============================================================

# --- Supabase [REQUIRED] -----------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=         # Supabase dashboard → Settings → API → service_role
SUPABASE_ANON_KEY=                 # Supabase dashboard → Settings → API → anon/public
SUPABASE_JWT_SECRET=               # Supabase dashboard → Settings → API → JWT Secret (HS256 signing)
DATABASE_URL=                      # Direct Postgres connection string (used by live-data module)

# JWT claim configuration (used for tenant-scoped RLS tokens)
SUPABASE_JWT_KEY=
SUPABASE_JWT_ALG=HS256
SUPABASE_JWT_AUD=authenticated
SUPABASE_JWT_SUB=
SUPABASE_JWT_ISS=
SUPABASE_JWT_EXPIRY=3600
SUPABASE_ACCESS_TOKEN=             # Supabase management API (admin scripts only)

# --- App URLs [REQUIRED] -----------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_BASE_URL=http://localhost:3001
NEXT_PUBLIC_DOMAIN=localhost

# --- Auth / Cron [REQUIRED] --------------------------------
CRON_SECRET=                       # Bearer token for cron route auth — any random string for local dev
NODE_ENV=development
SERVICE_TYPE=house-cleaning        # "house-cleaning" or "window-washing"

# --- Stripe [REQUIRED for payment flows] -------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...    # From `stripe listen --forward-to`
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
ENABLE_STRIPE_TEST_CHARGES=false
STRIPE_TEST_CHARGE_CENTS=100

# --- AI / LLM [OPTIONAL — needed for AI features] ---------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_UPDATE_MODEL=               # Override model for LLM update decider
OPENAI_CLEANER_MODEL=              # Override model for cleaner onboarding
OPENAI_INVOICE_NOTES_MODEL=        # Override model for invoice notes
YOUTUBE_API_KEY=                   # Brain knowledge ingestion from YouTube

# --- OpenPhone [OPTIONAL — needed for SMS] -----------------
OPENPHONE_API_KEY=
OPENPHONE_WEBHOOK_SECRET=
OPENPHONE_PHONE_ID=
OPENPHONE_PHONE_NUMBER=
OPENPHONE_PHONE_NUMBER_ID=
OPENPHONE_PHONE_ID_WINBROS=       # WinBros-specific phone ID

# --- VAPI [OPTIONAL — needed for voice AI] -----------------
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_ID=
VAPI_OUTBOUND_PHONE_ID=
VAPI_GHL_ASSISTANT_ID=
VAPI_ASSISTANT_ID_WINBROS=
VAPI_PHONE_ID_WINBROS=
ENABLE_VAPI_INBOUND=false
ENABLE_VAPI_OUTBOUND=false

# --- Google [OPTIONAL] -------------------------------------
GOOGLE_MAPS_API_KEY=               # Geocoding, address autocomplete
GOOGLE_CLOUD_NLP_API_KEY=          # Sentiment analysis
GOOGLE_LSA_CLIENT_ID=              # Local Services Ads
GOOGLE_LSA_CLIENT_SECRET=
GOOGLE_LSA_REFRESH_TOKEN=
GOOGLE_LSA_MANAGER_CID=
GOOGLE_LSA_CR_CLIENT_ID=           # Cedar Rapids LSA
GOOGLE_LSA_CR_CLIENT_SECRET=

# --- Telegram [OPTIONAL — needed for dispatch] -------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CONTROL_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- GoHighLevel [OPTIONAL] --------------------------------
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=
ENABLE_GHL=false

# --- HouseCall Pro [OPTIONAL] ------------------------------
HOUSECALL_PRO_API_KEY=
HOUSECALL_PRO_COMPANY_ID=
HOUSECALL_PRO_WEBHOOK_SECRET=
ENABLE_HOUSECALL_PRO=false

# --- HubSpot [OPTIONAL] ------------------------------------
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PIPELINE_ID=
HUBSPOT_STAGE_LEAD=
HUBSPOT_STAGE_QUOTED=
HUBSPOT_STAGE_SCHEDULED=
HUBSPOT_STAGE_COMPLETED=
HUBSPOT_STAGE_CANCELLED=
HUBSPOT_STAGE_DEFAULT=
ENABLE_HUBSPOT=false

# --- Email [OPTIONAL] --------------------------------------
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- QStash [OPTIONAL — async task queue] ------------------
QSTASH_TOKEN=
QSTASH_URL=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Meta / Facebook [OPTIONAL] ----------------------------
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
NEXT_PUBLIC_SPOTLESS_META_PIXEL=
NEXT_PUBLIC_SPOTLESS_GA4=
NEXT_PUBLIC_OSIRIS_META_PIXEL=
NEXT_PUBLIC_OSIRIS_GA4=

# --- DocuSign [OPTIONAL] -----------------------------------
DOCUSIGN_ACCESS_TOKEN=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_TEMPLATE_ID=
DOCUSIGN_BASE_URL=
DOCUSIGN_CLIENT_ROLE_NAME=
DOCUSIGN_CEO_ROLE_NAME=
DOCUSIGN_CEO_NAME=
DOCUSIGN_CEO_EMAIL=
DOCUSIGN_EMAIL_SUBJECT=
DOCUSIGN_EMAIL_BLURB=
ENABLE_DOCUSIGN=false

# --- Wave Accounting [OPTIONAL] ----------------------------
WAVE_ACCESS_TOKEN=
WAVE_BUSINESS_ID=
WAVE_INCOME_ACCOUNT_ID=

# --- Connecteam [OPTIONAL] ---------------------------------
CONNECTEAM_API_KEY=
CONNECTEAM_SCHEDULER_ID=
ENABLE_CONNECTEAM=false

# --- Owner / Admin -----------------------------------------
OWNER_PHONE=                       # Owner's phone for alerts
OWNER_PHONE_WINBROS=
ADMIN_EMAIL=

# --- Business Branding (per-tenant, or defaults) -----------
BUSINESS_NAME=
BUSINESS_NAME_SHORT=
BUSINESS_TAGLINE=
SDR_PERSONA=
FOUNDED_YEAR=
SERVICE_AREA=
SERVICES=
FREQUENCIES=
CLEANER_HOURLY_RATE=
DEPOSIT_PERCENT=
PROCESSING_FEE_PCT=
REVIEW_LINK=
TZ=America/New_York
DEFAULT_TIMEZONE=America/New_York

# --- Brand Routing -----------------------------------------
BRAND_MODE=                        # multi-brand routing
DEPLOYMENT_MODE=
BRAND_OPENPHONE_SPOTLESS=
BRAND_VAPI_SPOTLESS=
BRAND_GHL_SPOTLESS=
BRAND_OPENPHONE_WINBROS=
BRAND_VAPI_WINBROS=
BRAND_GHL_WINBROS=

# --- Bridge / Agent ----------------------------------------
AGENT_BRIDGE_SECRET=
SAM_WEBHOOK_SECRET=

# --- Feature Flags -----------------------------------------
ENABLE_FREE_COUCH_CLEANING=false
ENABLE_DYNAMIC_PRICING=false
ENABLE_WEATHER_BRIEFINGS=false
ENABLE_HIGH_VALUE_ALERTS=false
ENABLE_SERVICE_RADIUS_VALIDATION=false
ENABLE_CREW_PERFORMANCE_TRACKING=false
DYNAMIC_PRICING_MAX_DISCOUNT_PCT=
DYNAMIC_PRICING_MAX_MARKUP_PCT=
DYNAMIC_PRICING_MIN_CONFIDENCE=

# --- WinBros-specific --------------------------------------
WINBROS_SERVICE_ZIP=
WINBROS_SERVICE_RADIUS_MINUTES=
WINBROS_HIGH_VALUE_THRESHOLD_CENTS=
WINBROS_REVIEW_BONUS_CENTS=
WINBROS_UNDERFILL_THRESHOLD_JOBS=

# --- SMS Tuning --------------------------------------------
SMS_RESPONSE_DELAY_MS=
SMS_PAYMENT_LINK_DELAY_MS=

# --- Metrics / Targets -------------------------------------
DAILY_TARGET_PER_CREW=
DAILY_TARGET=
BOOKING_DAILY_TARGET=
