{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-push-tests.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "if": "Edit(*/app/api/**)|Write(*/app/api/**)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/route-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}